#!/usr/bin/env node
// Thin wrapper — delegates to the downloaded sqz-mcp binary
// Requirement 16.2: npx sqz-mcp

"use strict";

const path = require("path");
const { spawnSync } = require("child_process");

const ext = process.platform === "win32" ? ".exe" : "";
const binary = path.join(__dirname, `sqz-mcp${ext}`);

const result = spawnSync(binary, process.argv.slice(2), { stdio: "inherit" });

if (result.error) {
  if (result.error.code === "ENOENT") {
    console.error("sqz-mcp binary not found. Try reinstalling: npm install -g sqz-cli");
  } else {
    console.error("Failed to run sqz-mcp:", result.error.message);
  }
  process.exit(1);
}

process.exit(result.status ?? 0);
